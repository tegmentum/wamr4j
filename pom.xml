        </profile>

        <profile>
            <id>windows-x86_64</id>
            <activation>
                <os>
                    <family>windows</family>
                    <arch>amd64</arch>
                </os>
            </activation>
            <properties>
                <native.platform.classifier>windows-x86_64</native.platform.classifier>
                <rust.target>x86_64-pc-windows-msvc</rust.target>
                <native.library.name>wamr4j_native.dll</native.library.name>
