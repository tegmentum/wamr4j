        <!-- Cross-compilation profiles for building all platforms -->
        <profile>
            <id>native-all-platforms</id>
            <properties>
                <rust.targets>x86_64-unknown-linux-gnu,aarch64-unknown-linux-gnu,x86_64-apple-darwin,aarch64-apple-darwin,x86_64-pc-windows-msvc,aarch64-pc-windows-msvc</rust.targets>
            </properties>
        </profile>

        <!-- Skip native Rust compilation (use pre-built libraries from resources) -->
        <profile>
            <id>skip-native</id>
            <properties>
                <native.compile.skip>true</native.compile.skip>
            </properties>
        </profile>

        <!-- Mutation Testing Profile (cross-module: mutates API + impl classes using integration tests) -->
        <!-- Usage: ./mvnw test -P mutation-tests -pl wamr4j-tests -am -->
        <profile>
            <id>mutation-tests</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.pitest</groupId>
                        <artifactId>pitest-maven</artifactId>
                        <configuration>
                            <crossModule>true</crossModule>
                            <targetClasses>
                                <param>ai.tegmentum.wamr4j.*</param>
                                <param>ai.tegmentum.wamr4j.exception.*</param>
                                <param>ai.tegmentum.wamr4j.internal.*</param>
                                <param>ai.tegmentum.wamr4j.spi.*</param>
                                <param>ai.tegmentum.wamr4j.jni.*</param>
                                <param>ai.tegmentum.wamr4j.jni.impl.*</param>
                                <param>ai.tegmentum.wamr4j.jni.internal.*</param>
                                <param>ai.tegmentum.wamr4j.panama.*</param>
                                <param>ai.tegmentum.wamr4j.panama.impl.*</param>
                                <param>ai.tegmentum.wamr4j.panama.internal.*</param>
                                <param>ai.tegmentum.wamr4j.test.framework.*</param>
                            </targetClasses>
                            <targetTests>
                                <param>ai.tegmentum.wamr4j.*</param>
                            </targetTests>
                            <threads>2</threads>
                            <jvmArgs>
                                <jvmArg>--enable-native-access=ALL-UNNAMED</jvmArg>
                            </jvmArgs>
                        </configuration>
                        <executions>
                            <execution>
                                <id>mutation-testing</id>
                                <phase>test</phase>
                                <goals>
                                    <goal>mutationCoverage</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- Quick Mutation Testing Profile (API layer only, reduced mutators) -->
        <!-- Usage: ./mvnw test -P mutation-tests-quick -pl wamr4j-tests -am -->
        <profile>
            <id>mutation-tests-quick</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.pitest</groupId>
                        <artifactId>pitest-maven</artifactId>
                        <configuration>
                            <crossModule>true</crossModule>
                            <targetClasses>
                                <param>ai.tegmentum.wamr4j.RuntimeFactory</param>
                                <param>ai.tegmentum.wamr4j.WasiConfiguration</param>
                                <param>ai.tegmentum.wamr4j.HostFunction</param>
                                <param>ai.tegmentum.wamr4j.FunctionSignature</param>
                                <param>ai.tegmentum.wamr4j.test.framework.*</param>
                            </targetClasses>
                            <targetTests>
                                <param>ai.tegmentum.wamr4j.*</param>
                            </targetTests>
                            <threads>2</threads>
                            <mutators>
                                <mutator>CONDITIONALS_BOUNDARY</mutator>
                                <mutator>NEGATE_CONDITIONALS</mutator>
                                <mutator>MATH</mutator>
                                <mutator>VOID_METHOD_CALLS</mutator>
                                <mutator>FALSE_RETURNS</mutator>
                                <mutator>TRUE_RETURNS</mutator>
                                <mutator>EMPTY_RETURNS</mutator>
                                <mutator>NULL_RETURNS</mutator>
                                <mutator>PRIMITIVE_RETURNS</mutator>
                            </mutators>
                            <timeoutConstant>5000</timeoutConstant>
                            <jvmArgs>
                                <jvmArg>--enable-native-access=ALL-UNNAMED</jvmArg>
                            </jvmArgs>
                        </configuration>
                        <executions>
                            <execution>
                                <id>quick-mutation-testing</id>
                                <phase>test</phase>
                                <goals>
                                    <goal>mutationCoverage</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- Thorough Mutation Testing Profile (all mutators, all packages — CI/scheduled use) -->
        <!-- Usage: ./mvnw test -P mutation-tests-thorough -pl wamr4j-tests -am -->
        <profile>
            <id>mutation-tests-thorough</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.pitest</groupId>
                        <artifactId>pitest-maven</artifactId>
                        <configuration>
                            <crossModule>true</crossModule>
                            <targetClasses>
                                <param>ai.tegmentum.wamr4j.*</param>
                                <param>ai.tegmentum.wamr4j.exception.*</param>
                                <param>ai.tegmentum.wamr4j.internal.*</param>
                                <param>ai.tegmentum.wamr4j.spi.*</param>
                                <param>ai.tegmentum.wamr4j.jni.*</param>
                                <param>ai.tegmentum.wamr4j.jni.impl.*</param>
                                <param>ai.tegmentum.wamr4j.jni.internal.*</param>
                                <param>ai.tegmentum.wamr4j.panama.*</param>
                                <param>ai.tegmentum.wamr4j.panama.impl.*</param>
                                <param>ai.tegmentum.wamr4j.panama.internal.*</param>
                                <param>ai.tegmentum.wamr4j.test.framework.*</param>
                            </targetClasses>
                            <targetTests>
                                <param>ai.tegmentum.wamr4j.*</param>
                            </targetTests>
                            <mutators>
                                <mutator>ALL</mutator>
                            </mutators>
                            <failWhenNoMutations>true</failWhenNoMutations>
                            <timeoutConstant>15000</timeoutConstant>
                            <timeoutFactor>2.0</timeoutFactor>
                            <threads>2</threads>
                            <jvmArgs>
                                <jvmArg>--enable-native-access=ALL-UNNAMED</jvmArg>
                            </jvmArgs>
                        </configuration>
                        <executions>
                            <execution>
                                <id>thorough-mutation-testing</id>
                                <phase>test</phase>
                                <goals>
                                    <goal>mutationCoverage</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- Release profile for Maven Central publishing -->
        <profile>
            <id>release</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-source-plugin</artifactId>
                        <version>${maven-source-plugin.version}</version>
                        <executions>
                            <execution>
                                <id>attach-sources</id>
                                <goals>
                                    <goal>jar-no-fork</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-javadoc-plugin</artifactId>
                        <version>${maven-javadoc-plugin.version}</version>
                        <executions>
                            <execution>
                                <id>attach-javadocs</id>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-gpg-plugin</artifactId>
                        <version>3.1.0</version>
                        <executions>
                            <execution>
                                <id>sign-artifacts</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>sign</goal>
                                </goals>
                                <configuration>
                                    <gpgArguments>
                                        <arg>--pinentry-mode</arg>
                                        <arg>loopback</arg>
                                    </gpgArguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <groupId>org.sonatype.central</groupId>
                        <artifactId>central-publishing-maven-plugin</artifactId>
                        <version>0.7.0</version>
                        <extensions>true</extensions>
                        <configuration>
                            <publishingServerId>central</publishingServerId>
                            <autoPublish>true</autoPublish>
                            <waitUntil>published</waitUntil>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

    </profiles>
</project>